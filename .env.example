# APP_URL: The URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://example.com"

# GITHUB_TOKEN: Optional GitHub Personal Access Token (PAT).
# Strongly recommended to elevate GitHub Search API rate-limit boundaries from 60 to 5000 requests/hour.
# Set via environment variables in production or a local .env configuration.
GITHUB_TOKEN=""
